# Google Maps JavaScript API key (client-side, restrict to HTTP referrers)
# Enable: Maps JavaScript API, Places API (New), Street View Static API, Maps Static API
# Restrict to: https://*.vercel.app/* and http://localhost:3000/*
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Runware API key (server-side, never expose to client)
# Powers AI listing copy generation + photo critique vision analysis
RUNWARE_API_KEY=
